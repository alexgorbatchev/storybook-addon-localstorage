{
  "name": "@alexgorbatchev/storybook-addon-localstorage",
  "version": "2.0.3",
  "description": "A Storybook v8 addong for mocking and displaying `localStorage` values",
  "keywords": [
    "storybook-addons",
    "localStorage",
    "test",
    "mocking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alexgorbatchev/storybook-addon-localstorage"
  },
  "authors": [
    "Alex Gorbatchev <alex.gorbatchev@gmail.com>"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./preset": {
      "import": {
        "types": "./dist/preset.d.ts",
        "default": "./dist/preset.js"
      },
      "require": {
        "types": "./dist/preset.d.cts",
        "default": "./dist/preset.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "*.png",
    "!src/**/*"
  ],
  "scripts": {
    "storybook": "storybook dev --port 6006",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@storybook/react": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.2.17",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "use-local-storage-state": "^19.5.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "storybook": {
    "displayName": "localStorage",
    "supportedFrameworks": [
      "react"
    ],
    "icon": "https://user-images.githubusercontent.com/321738/63501763-88dbf600-c4cc-11e9-96cd-94adadc2fd72.png"
  }
}
